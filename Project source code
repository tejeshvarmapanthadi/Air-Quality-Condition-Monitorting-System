# Air Quality Monitoring System using Data Analytics

# Import Libraries
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns

# Load Dataset
data = pd.read_csv("air_quality_dataset.csv")

print("First Five Rows of Dataset")
print(data.head())

# Dataset Information
print("\nDataset Information")
print(data.info())

# Statistical Summary
print("\nStatistical Summary")
print(data.describe())

# Check Missing Values
print("\nMissing Values")
print(data.isnull().sum())

# Fill Missing Values
data.fillna(method='ffill', inplace=True)

# AQI Calculation Function
def calculate_aqi(pm25):
    if pm25 <= 50:
        return "Good"
    elif pm25 <= 100:
        return "Moderate"
    elif pm25 <= 150:
        return "Unhealthy for Sensitive Groups"
    elif pm25 <= 200:
        return "Unhealthy"
    elif pm25 <= 300:
        return "Very Unhealthy"
    else:
        return "Hazardous"

# Apply AQI Category
data['AQI_Category'] = data['PM2.5'].apply(calculate_aqi)

print("\nAQI Category Distribution")
print(data['AQI_Category'].value_counts())

# Average Pollution Levels
print("\nAverage Pollution Levels")
print(data[['PM2.5','PM10','NO2','CO','SO2','O3']].mean())

# Highest Pollution Day
max_pollution = data.loc[data['PM2.5'].idxmax()]
print("\nHighest Pollution Record")
print(max_pollution)

# Line Graph for PM2.5
plt.figure(figsize=(10,5))
plt.plot(data['PM2.5'], marker='o')
plt.title("PM2.5 Pollution Trend")
plt.xlabel("Days")
plt.ylabel("PM2.5 Level")
plt.show()

# Line Graph for PM10
plt.figure(figsize=(10,5))
plt.plot(data['PM10'], marker='o')
plt.title("PM10 Pollution Trend")
plt.xlabel("Days")
plt.ylabel("PM10 Level")
plt.show()

# Temperature vs Pollution
plt.figure(figsize=(8,5))
plt.scatter(data['Temperature'], data['PM2.5'])
plt.title("Temperature vs PM2.5")
plt.xlabel("Temperature")
plt.ylabel("PM2.5")
plt.show()

# Humidity vs Pollution
plt.figure(figsize=(8,5))
plt.scatter(data['Humidity'], data['PM2.5'])
plt.title("Humidity vs PM2.5")
plt.xlabel("Humidity")
plt.ylabel("PM2.5")
plt.show()

# Correlation Matrix
plt.figure(figsize=(8,6))
sns.heatmap(data.corr(numeric_only=True), annot=True)
plt.title("Correlation Between Air Pollutants")
plt.show()

# Histogram of AQI
plt.figure(figsize=(8,5))
sns.histplot(data['PM2.5'], bins=10, kde=True)
plt.title("Distribution of PM2.5 Levels")
plt.xlabel("PM2.5")
plt.ylabel("Frequency")
plt.show()

# Pollution Category Count Plot
plt.figure(figsize=(8,5))
sns.countplot(x='AQI_Category', data=data)
plt.title("AQI Category Distribution")
plt.xticks(rotation=45)
plt.show()

# Predict Future Pollution (Simple Moving Average)
data['PM25_Predicted'] = data['PM2.5'].rolling(window=3).mean()

plt.figure(figsize=(10,5))
plt.plot(data['PM2.5'], label="Actual PM2.5")
plt.plot(data['PM25_Predicted'], label="Predicted PM2.5", linestyle='--')
plt.legend()
plt.title("PM2.5 Prediction using Moving Average")
plt.show()

print("\nPredicted Pollution Values")
print(data[['PM2.5','PM25_Predicted']].tail())

# Save Processed Data
data.to_csv("processed_air_quality_data.csv", index=False)

print("\nProcessed dataset saved successfully.")
